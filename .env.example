# Copy this file to `.env` and fill in your Anthropic API key.
# `docker compose up` reads `.env` automatically.

# Required for the agent chat endpoints. Without it the scrape
# pipeline still runs; only /api/agent/* fails.
ANTHROPIC_API_KEY=

# Optional. Defaults match what the Dockerfile / app expect, but
# uncomment to override.
# JOBAI_DB_PATH=/data/jobai.db
# JOBAI_LOG_LEVEL=INFO
