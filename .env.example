# Copy this file to `.env` and fill in the values you need.
# `docker compose up` reads `.env` automatically.

# ---------------------------------------------------------------------------
# Agent backend — pick how the chat dock authenticates.
# ---------------------------------------------------------------------------
#
# `api`           — default. Uses the Anthropic API directly with
#                   ANTHROPIC_API_KEY (below). Pay-per-token.
# `subscription`  — uses your Claude Pro/Max subscription via the
#                   `claude` CLI bundled into the image. Requires a
#                   long-lived token: run `claude setup-token` on
#                   your host (it'll print a sk-ant-oat-… token),
#                   then paste it into CLAUDE_CODE_OAUTH_TOKEN below.
#                   No API key needed; calls bill against your Max
#                   quota.
#
JOBAI_AGENT_BACKEND=api

# ---------------------------------------------------------------------------
# API-key mode credentials (only used when JOBAI_AGENT_BACKEND=api).
# Get a key from https://console.anthropic.com → Settings → API Keys.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Subscription-mode token (only used when JOBAI_AGENT_BACKEND=subscription).
# Generate with: `claude setup-token` on your host machine while
# logged in. The token starts with `sk-ant-oat-`. Treat it as a
# secret — anyone with it can use your Max quota.
# ---------------------------------------------------------------------------
CLAUDE_CODE_OAUTH_TOKEN=

# ---------------------------------------------------------------------------
# Optional. Defaults match what the Dockerfile / app expect, but
# uncomment to override.
# ---------------------------------------------------------------------------
# JOBAI_DB_PATH=/data/jobai.db
# JOBAI_LOG_LEVEL=INFO
# JOBAI_ANTHROPIC_MODEL=claude-opus-4-7
